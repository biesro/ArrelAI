# ==========================================
#   ARREL AI — .gitignore
# ==========================================

# ==========================================
# PYTHON
# ==========================================
# Bytecode compilat
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribucions / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Entorns virtuals
venv/
env/
ENV/
env.bak/
venv.bak/

# PyCharm
.idea/

# ==========================================
# CHROMADB & BASES DE DADES
# ==========================================
chroma_db/
*.db
*.sqlite
*.sqlite3

# ==========================================
# CONFIGURACIÓ SENSIBLE
# ==========================================
.env
.env.local
.env.production
*.log

# ==========================================
# REACT / NODE.JS
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build de producció
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ==========================================
# TESTING
# ==========================================
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ==========================================
# JUPYTER / IPYTHON
# ==========================================
.ipynb_checkpoints/
*.ipynb

# ==========================================
# SISTEMA OPERATIU
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ==========================================
# IDEs & EDITORS
# ==========================================
# VSCode
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ==========================================
# TEMPORAL & LOGS
# ==========================================
*.log
*.tmp
*.temp
tmp/
temp/

# ==========================================
# BACKUPS
# ==========================================
*.bak
*.backup
*.old
