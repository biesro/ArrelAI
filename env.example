# ==========================================
#   ARREL AI — CONFIGURACIÓ D'ENTORN
# ==========================================
# Copia aquest fitxer a .env i ajusta els valors segons el teu sistema

# ==========================================
# OLLAMA
# ==========================================
# Servidor Ollama local (no cal canviar si uses la configuració per defecte)
OLLAMA_HOST=http://127.0.0.1:11434

# ==========================================
# FILE WATCHER
# ==========================================
# Carpeta on posaries documents per indexar-los automàticament
# IMPORTANT: Canvia això al teu path real!
#
# Exemples:
# Windows:  C:\Users\TeuNom\Arrel_AI
# Linux:    /home/teunom/Arrel_AI
# Mac:      /Users/TeuNom/Arrel_AI
#
# També pots usar ~ (directori home):
WATCH_FOLDER=~/Arrel_AI

# ==========================================
# MODELS OLLAMA
# ==========================================
# Assegura't de baixar-los primer amb:
# ollama pull qwen3:8b
# ollama pull qwen2.5-coder:7b
# ollama pull qwen3-vl:4b
# ollama pull qwen3-embedding:0.6b

MODEL_GENERAL=qwen3:8b
MODEL_SCIENCE=qwen3:8b
MODEL_PROGRAMMING=qwen2.5-coder:7b
MODEL_VISION=qwen3-vl:4b

# Model per generar embeddings (RAG)
EMBED_MODEL=qwen3-embedding:0.6b

# ==========================================
# RAG (Retrieval-Augmented Generation)
# ==========================================
# Threshold de similaritat cosinus (0.0 - 1.0)
# Valors més alts = només context molt rellevant
# Valors més baixos = més permissiu
RAG_THRESHOLD=0.25

# Quants documents retornar després del reranking
RAG_N_RESULTS=6

# Pipeline intern (normalment no cal tocar):
# RAG_N_RETRIEVAL=15  # Candidats inicials de ChromaDB
# RAG_N_FINAL=5       # Top N després de FlashRank

# ==========================================
# SANDBOX
# ==========================================
# Timeout màxim per execucions de Python (en segons)
# Evita bucles infinits
SANDBOX_TIMEOUT=30

# ==========================================
# MULTI-AGENT SYSTEM
# ==========================================
# Màxim d'intents de verificació de codi
MAX_RETRIES=6

# ==========================================
# RESEARCH MODE
# ==========================================
# Màxim de passos d'investigació iterativa
MAX_RESEARCH_STEPS=6

# Mínim de passos abans de permetre acabar
# (assegura que el model investiga prou)
MIN_RESEARCH_STEPS=3

# ==========================================
# SELF-REFLECTION SYSTEM
# ==========================================
# Activar el sistema d'auto-crítica
ENABLE_SELF_REFLECTION=true

# Cada quants passos fer reflexió (1 = sempre)
REFLECTION_FREQUENCY=1
